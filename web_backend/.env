# ADK Backend
ADK_BASE_URL=http://127.0.0.1:8000
ADK_APP_NAME=adk_backend

# ADK Artifact 경로 (Windows 경로는 그대로 사용)
ADK_ARTIFACT_ROOT=C:/MyFolder/LLM/google-adk/.adk/artifacts

# MCP Resource 저장 경로 (mcp_server/.env의 MCP_RESOURCE_ROOT와 동일하게)
MCP_RESOURCE_ROOT=C:/MyFolder/LLM/google-adk/.mcp/resources

# 워크스페이스 파일 디렉토리
WORKSPACE_FILES_DIR=C:/MyFolder/data

# Web Backend
WEB_BACKEND_HOST=0.0.0.0
WEB_BACKEND_PORT=8080
